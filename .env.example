# Copy this file to `.env` (or set these as real environment variables in your
# MCP client config) and fill in the values from your Spotify app dashboard:
#   https://developer.spotify.com/dashboard
#
# 1. Create an app.
# 2. Add a Redirect URI that EXACTLY matches SPOTIFY_REDIRECT_URI below
#    (Spotify requires loopback redirect URIs to use 127.0.0.1, not localhost).
# 3. Copy the Client ID here. The Client Secret is optional — this server uses
#    the Authorization Code with PKCE flow by default and does not need it.

# Required.
SPOTIFY_CLIENT_ID=your_client_id_here

# Optional. If set, the classic Authorization Code flow (with client secret) is
# used instead of PKCE. Leave blank/unset to use PKCE (recommended for local apps).
# SPOTIFY_CLIENT_SECRET=

# Optional. Must EXACTLY match a Redirect URI registered on your Spotify app.
# Defaults to http://127.0.0.1:8888/callback if unset.
# SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional. Where the OAuth token cache is stored.
# Defaults to ~/.spotify-mcp/token.json
# SPOTIFY_MCP_CACHE=
